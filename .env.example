# Supabase (le variabili NEXT_PUBLIC_ / pubbliche vanno in window.__ENV__ di ogni HTML page)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Resend — solo server-side (Vercel Function api/contatti.js)
RESEND_API_KEY=re_xxxx
CONTACT_TO=info@cascinafontana.xyz
CONTACT_FROM=noreply@cascinafontana.xyz

# PayPal — solo server-side (Vercel Functions)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox    # oppure: live
