# ── Supabase ─────────────────────────────────────────────────────────────────
# Chiave pubblica (anon) — iniettata in window.__ENV__ di ogni pagina HTML
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Chiave privata (service role) — solo server-side, MAI esposta al browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend ────────────────────────────────────────────────────────────────────
# Usata solo da api/contatti.js (Vercel Function)
RESEND_API_KEY=re_xxxx
CONTACT_TO=info@cascinafontana.xyz
CONTACT_FROM=noreply@cascinafontana.xyz

# ── PayPal ────────────────────────────────────────────────────────────────────
# Usate solo da api/paypal-order.js e api/paypal-capture.js (Vercel Functions)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox    # oppure: live
